# SAM.gov API Configuration
# For production, each user sets their own API key in the Settings page
# This is a fallback/default key for the application
SAM_API_KEY=your_sam_gov_api_key_here

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=production
FLASK_DEBUG=False

# Database Configuration
# SQLite is used by default - no changes needed
DATABASE_URL=sqlite:///database.db
